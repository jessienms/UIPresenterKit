#damage-root {
    position: absolute;
    flex-grow: 0;
    align-items: center;
}

#damage-label {
    font-size: 28px;
    color: rgb(255, 80, 60);
    -unity-font-style: bold;
    -unity-text-outline-width: 1.5px;
    -unity-text-outline-color: rgb(0, 0, 0);
    white-space: nowrap;
    margin: 0;
    padding: 0;
}
